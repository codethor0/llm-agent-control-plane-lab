# Production reference profile (fake values only; do not commit real secrets)
# Mount API keys via secret manager or read-only file; see deploy/examples/fake-api-keys.txt

ACP_ENVIRONMENT=production
ACP_POLICY_PATH=/app/policies/default.yaml
ACP_AUDIT_LOG_DIR=/tmp/audit
ACP_AUDIT_RETENTION_DAYS=90
ACP_MAX_REQUEST_BODY_BYTES=1048576

# Required in production: explicit front-end origins (no wildcard)
ACP_ALLOWED_ORIGINS=https://app.example.invalid

# API authentication required before exposing /run
ACP_REQUIRE_API_AUTH=true
ACP_ALLOWED_API_KEYS_FILE=/run/secrets/api_keys.txt

# Safe error responses only
ACP_ENABLE_DEBUG_ERRORS=false

# Simulated control plane only
ACP_ALLOW_LIVE_EXTERNAL_TOOLS=false
ACP_ALLOW_SHELL_TOOLS=false
ACP_LLM_ADAPTER_MODE=simulated
ACP_ALLOW_LIVE_LLM_CALLS=false

# Optional strict controls (enable with secret-managed key file)
ACP_ENABLE_STRICT_PROVENANCE=false
ACP_REQUIRE_APPROVAL_TOKEN=false
ACP_ENABLE_RATE_LIMIT_GUIDANCE=true

# TLS terminates at reverse proxy; do not expose this service publicly without TLS and auth
