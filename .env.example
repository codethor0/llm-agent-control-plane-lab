# Local lab configuration (no secrets)
ACP_ENVIRONMENT=local
ACP_POLICY_PATH=./policies/default.yaml
ACP_AUDIT_LOG_DIR=./audit_logs
ACP_MAX_REQUEST_BODY_BYTES=1048576
ACP_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
ACP_REQUIRE_API_AUTH=false
ACP_ENABLE_DEBUG_ERRORS=true
ACP_ENABLE_STRICT_PROVENANCE=false
ACP_REQUIRE_APPROVAL_TOKEN=false
ACP_ENABLE_RATE_LIMIT_GUIDANCE=true
ACP_ALLOW_LIVE_EXTERNAL_TOOLS=false
ACP_ALLOW_SHELL_TOOLS=false
ACP_LLM_ADAPTER_MODE=simulated
ACP_ALLOW_LIVE_LLM_CALLS=false

# Production reference profile (fake values): see .env.production.example
# Compose: docker compose -f docker-compose.production.yml up --build
# Kubernetes: deploy/kubernetes/README.md

AUDIT_LOG_PATH=./audit_logs/events.jsonl
POLICY_PATH=./policies/default.yaml
DEMO_MODE=protected
